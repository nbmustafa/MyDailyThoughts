<body>

<h1>EKS Managed Platform — RBAC Architecture</h1>
<div class="subtitle">Principal Security + Platform Engineering Design · AWS EKS · Access Entries · ArgoCD · Karpenter</div>

<div class="canvas">

  <!-- ═══════════════════════════════════════════════════
       ROW 1 — IAM Roles + Access Entries
  ════════════════════════════════════════════════════ -->
  <div class="row-top">

    <!-- IAM Roles -->
    <div class="box iam-panel">
      <span class="box-label">AWS IAM Roles</span>
      <div class="roles-grid">

        <div class="iam-role platform-write">
          <div class="role-name" style="color:var(--platform-blue)">Platform Admin</div>
          <div class="role-arn">arn:aws:iam::ACCOUNT:role/<br>eks-platform-admin-role</div>
          <span class="tag" style="background:var(--platform-blue-dim);color:var(--platform-blue)">CLUSTER WRITE</span>
        </div>

        <div class="iam-role platform-read">
          <div class="role-name" style="color:var(--read-teal)">Platform ReadOnly</div>
          <div class="role-arn">arn:aws:iam::ACCOUNT:role/<br>eks-platform-readonly-role</div>
          <span class="tag" style="background:var(--read-teal-dim);color:var(--read-teal)">CLUSTER READ</span>
        </div>

        <div class="iam-role tenant-write">
          <div class="role-name" style="color:var(--tenant-green)">Tenant Write</div>
          <div class="role-arn">arn:aws:iam::ACCOUNT:role/<br>eks-tenant-{name}-write-role</div>
          <span class="tag" style="background:var(--tenant-green-dim);color:var(--tenant-green)">NS SCOPED WRITE</span>
        </div>

        <div class="iam-role tenant-read">
          <div class="role-name" style="color:var(--write-amber)">Tenant ReadOnly</div>
          <div class="role-arn">arn:aws:iam::ACCOUNT:role/<br>eks-tenant-{name}-read-role</div>
          <span class="tag" style="background:var(--write-amber-dim);color:var(--write-amber)">CLUSTER READ</span>
        </div>

      </div>
    </div>

    <!-- Access Entries (replacing aws-auth) -->
    <div class="box access-panel">
      <span class="box-label">EKS Access Entries (API Auth Mode)</span>

      <div class="entry-row">
        <div class="entry-iam">eks-platform-admin-role</div>
        <div class="arrow-mid">→</div>
        <div class="entry-k8s" style="color:var(--platform-blue)">
          <div style="font-size:9px;color:var(--text-dim);margin-bottom:2px">K8S GROUP</div>
          platform-admins
        </div>
      </div>

      <div class="entry-row">
        <div class="entry-iam">eks-platform-readonly-role</div>
        <div class="arrow-mid">→</div>
        <div class="entry-k8s" style="color:var(--read-teal)">
          <div style="font-size:9px;color:var(--text-dim);margin-bottom:2px">K8S GROUP</div>
          platform-readers
        </div>
      </div>

      <div class="entry-row">
        <div class="entry-iam">eks-tenant-{name}-write-role</div>
        <div class="arrow-mid">→</div>
        <div class="entry-k8s" style="color:var(--tenant-green)">
          <div style="font-size:9px;color:var(--text-dim);margin-bottom:2px">K8S GROUP</div>
          tenant-{name}-writers
        </div>
      </div>

      <div class="entry-row">
        <div class="entry-iam">eks-tenant-{name}-read-role</div>
        <div class="arrow-mid">→</div>
        <div class="entry-k8s" style="color:var(--write-amber)">
          <div style="font-size:9px;color:var(--text-dim);margin-bottom:2px">K8S GROUP</div>
          tenant-readers
        </div>
      </div>

      <div style="margin-top:14px;padding:8px 10px;background:rgba(168,85,247,0.06);border:1px solid rgba(168,85,247,0.2);border-radius:6px;font-size:9px;color:var(--rbac-purple)">
        ⚑ &nbsp;authenticationMode: API_AND_CONFIG_MAP → API &nbsp;·&nbsp; No aws-auth ConfigMap
      </div>
    </div>
  </div>

  <!-- connector -->
  <div class="connector-row">
    <div class="connector-line"></div>
    <span class="badge">binds to k8s rbac</span>
    <div class="connector-line"></div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       ROW 2 — EKS Cluster
  ════════════════════════════════════════════════════ -->
  <div class="box cluster-box">
    <span class="box-label">EKS Cluster — eks-platform-prod</span>
    <div class="cluster-inner">

      <!-- Platform Namespaces (left column) -->
      <div class="platform-ns-panel">
        <div class="panel-title">
          <span>🔒</span> Platform Namespaces
          <span class="tag" style="background:var(--platform-blue-dim);color:var(--platform-blue);margin-left:auto">PLATFORM MANAGED</span>
        </div>
        <div>
          <span class="ns-chip highlight">argocd</span>
          <span class="ns-chip highlight">karpenter</span>
          <span class="ns-chip highlight">monitoring</span>
          <span class="ns-chip highlight">cert-manager</span>
          <span class="ns-chip highlight">external-dns</span>
          <span class="ns-chip highlight">ingress-nginx</span>
          <span class="ns-chip highlight">external-secrets</span>
          <span class="ns-chip highlight">kube-system</span>
          <span class="ns-chip">velero</span>
          <span class="ns-chip">falco</span>
        </div>
        <div style="margin-top:12px;font-size:9px;color:var(--text-dim);line-height:1.6">
          ▸ Platform team has full write access<br>
          ▸ Tenants have NO access to these NSes<br>
