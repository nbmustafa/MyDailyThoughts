###############################################################################
# ArgoCD — Platform App-of-Apps
# This Application boots all platform components.
# Deployed once by the platform team during cluster bootstrap.
###############################################################################
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: platform-app-of-apps
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
  labels:
    platform.io/managed: "true"
    platform.io/component: "app-of-apps"
spec:
  project: platform

  source:
    repoURL: https://github.com/your-org/platform-gitops
    targetRevision: main
    path: apps/platform

  destination:
    server: https://kubernetes.default.svc
    namespace: argocd

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - PrunePropagationPolicy=foreground
      - PruneLast=true
    retry:
      limit: 5
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m

---
###############################################################################
# ArgoCD AppProject — Platform
# Only platform team can manage platform components.
###############################################################################
apiVersion: argoproj.io/v1alpha1
kind: AppProject
metadata:
  name: platform
  namespace: argocd
spec:
  description: "Platform managed components — platform team only"

  sourceRepos:
    - https://github.com/your-org/platform-gitops
    - https://argoproj.github.io/argo-helm
    - oci://public.ecr.aws/karpenter
    - https://charts.bitnami.com/bitnami
    - https://prometheus-community.github.io/helm-charts
    - https://charts.jetstack.io

  destinations:
    - server: https://kubernetes.default.svc
      namespace: "*"    # platform project can deploy anywhere

  clusterResourceWhitelist:
    - group: "*"
      kind: "*"

  namespaceResourceWhitelist:
    - group: "*"
      kind: "*"

  roles:
    - name: platform-admin
      description: Platform engineers full access
      policies:
        - p, proj:platform:platform-admin, applications, *, platform/*, allow
      groups:
        - platform-admins

    - name: platform-readonly
      description: Platform read-only access
      policies:
        - p, proj:platform:platform-readonly, applications, get, platform/*, allow
        - p, proj:platform:platform-readonly, applications, sync, platform/*, deny
      groups:
        - platform-readers

---
###############################################################################
# ArgoCD AppProject — Tenants
# Tenants can ONLY deploy to their own namespaces.
###############################################################################
apiVersion: argoproj.io/v1alpha1
kind: AppProject
metadata:
  name: tenants
  namespace: argocd
spec:
  description: "Tenant workloads — tenants manage their own apps"

  sourceRepos:
    - "*"   # tenants can use any repo (restrict further per-tenant if needed)

  destinations:
    # Tenants can only target tenant-prefixed namespaces
    - server: https://kubernetes.default.svc
      namespace: tenant-*

  # Tenants CANNOT create cluster-scoped resources
  clusterResourceWhitelist: []

  namespaceResourceWhitelist:
    - group: ""
      kind: "ConfigMap"
    - group: ""
      kind: "Secret"
    - group: ""
      kind: "Service"
    - group: ""
      kind: "ServiceAccount"
    - group: ""
      kind: "PersistentVolumeClaim"
    - group: "apps"
      kind: "Deployment"
    - group: "apps"
      kind: "StatefulSet"
    - group: "batch"
      kind: "CronJob"
    - group: "batch"
      kind: "Job"
    - group: "autoscaling"
      kind: "HorizontalPodAutoscaler"
    - group: "networking.k8s.io"
      kind: "Ingress"
    - group: "policy"
      kind: "PodDisruptionBudget"
    - group: "external-secrets.io"
      kind: "ExternalSecret"
    - group: "argoproj.io"
      kind: "Application"
    # Karpenter — tenants can manage their own NodePools
    - group: "karpenter.sh"
      kind: "NodePool"
    - group: "karpenter.k8s.aws"
      kind: "EC2NodeClass"

  roles:
    - name: tenant-write
      description: Tenant engineers — deploy apps
      policies:
        - p, proj:tenants:tenant-write, applications, *, tenants/*, allow
      groups:
        - tenant-team-alpha-writers
        - tenant-team-beta-writers

    - name: tenant-readonly
      description: Tenant read-only observers
      policies:
        - p, proj:tenants:tenant-readonly, applications, get, tenants/*, allow
        - p, proj:tenants:tenant-readonly, applications, sync, tenants/*, deny
      groups:
        - tenant-readers

###############################################################################
# ClusterRoles — Platform Admin, Platform ReadOnly, Tenant ReadOnly
###############################################################################

---
# ═══════════════════════════════════════════════════════════════════════════
# PLATFORM ADMIN ClusterRole
# Full write access to ALL resources across the entire cluster.
# Bound to K8s group: platform-admins (mapped from IAM via Access Entry)
# ═══════════════════════════════════════════════════════════════════════════
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: {{ .Values.platformAdmin.clusterRoleName }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/role-type: platform-admin
  annotations:
    platform.io/description: "Full write access to all cluster resources. Platform engineers only."
    platform.io/sensitivity: "critical"
rules:
  # ── All resources, all API groups ──────────────────────────────────────
  - apiGroups: ["*"]
    resources: ["*"]
    verbs: ["*"]
  # ── Non-resource URLs (health, metrics, proxy) ─────────────────────────
  - nonResourceURLs: ["*"]
    verbs: ["*"]

---
# ═══════════════════════════════════════════════════════════════════════════
# PLATFORM READONLY ClusterRole
# Read-only access to ALL resources across the entire cluster.
# Bound to K8s group: platform-readers
# Notable restriction: Secrets list only (no get/watch — prevents exfiltration)
# ═══════════════════════════════════════════════════════════════════════════
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: {{ .Values.platformReadonly.clusterRoleName }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/role-type: platform-readonly
  annotations:
    platform.io/description: "Read-only access to all cluster resources. Platform on-call and audit."
rules:
  # ── Core resources (pods, nodes, namespaces, services, etc.) ──────────
  - apiGroups: [""]
    resources:
      - configmaps
      - endpoints
      - events
      - limitranges
      - namespaces
      - nodes
      - persistentvolumeclaims
      - persistentvolumes
      - pods
      - pods/log
      - replicationcontrollers
      - resourcequotas
      - serviceaccounts
      - services
    verbs: ["get", "list", "watch"]
  # ── Secrets: list ONLY — can see that secrets exist, not their values ──
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["list"]
  # ── Apps resources ──────────────────────────────────────────────────────
  - apiGroups: ["apps"]
    resources:
      - daemonsets
      - deployments
      - replicasets
      - statefulsets
    verbs: ["get", "list", "watch"]
  # ── Batch ───────────────────────────────────────────────────────────────
  - apiGroups: ["batch"]
    resources: ["cronjobs", "jobs"]
    verbs: ["get", "list", "watch"]
  # ── Autoscaling ─────────────────────────────────────────────────────────
  - apiGroups: ["autoscaling"]
    resources: ["horizontalpodautoscalers"]
    verbs: ["get", "list", "watch"]
  # ── Networking ──────────────────────────────────────────────────────────
  - apiGroups: ["networking.k8s.io"]
    resources: ["ingresses", "ingressclasses", "networkpolicies"]
    verbs: ["get", "list", "watch"]
  # ── Policy ──────────────────────────────────────────────────────────────
  - apiGroups: ["policy"]
    resources: ["poddisruptionbudgets"]
    verbs: ["get", "list", "watch"]
  # ── RBAC — read only (to audit permissions) ─────────────────────────────
  - apiGroups: ["rbac.authorization.k8s.io"]
    resources:
      - clusterroles
      - clusterrolebindings
      - roles
      - rolebindings
    verbs: ["get", "list", "watch"]
  # ── Storage ─────────────────────────────────────────────────────────────
  - apiGroups: ["storage.k8s.io"]
    resources: ["storageclasses", "volumeattachments"]
    verbs: ["get", "list", "watch"]
  # ── Karpenter ───────────────────────────────────────────────────────────
  - apiGroups: ["karpenter.sh"]
    resources: ["nodepools", "nodeclaims"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["karpenter.k8s.aws"]
    resources: ["ec2nodeclasses"]
    verbs: ["get", "list", "watch"]
  # ── ArgoCD ──────────────────────────────────────────────────────────────
  - apiGroups: ["argoproj.io"]
    resources: ["applications", "applicationsets", "appprojects"]
    verbs: ["get", "list", "watch"]
  # ── Metrics ─────────────────────────────────────────────────────────────
  - apiGroups: ["metrics.k8s.io"]
    resources: ["nodes", "pods"]
    verbs: ["get", "list"]
  # ── CRDs ────────────────────────────────────────────────────────────────
  - apiGroups: ["apiextensions.k8s.io"]
    resources: ["customresourcedefinitions"]
    verbs: ["get", "list", "watch"]
  # ── Non-resource URLs ───────────────────────────────────────────────────
  - nonResourceURLs: ["/healthz", "/readyz", "/livez", "/metrics", "/version"]
    verbs: ["get"]

---
# ═══════════════════════════════════════════════════════════════════════════
# TENANT READONLY ClusterRole
# Read access cluster-wide but with stricter limits than platform-readonly.
# Tenants can observe workloads for debugging but cannot see secrets or
# access sensitive control-plane resources.
# Bound to K8s group: tenant-readers (shared across all tenant read roles)
# ═══════════════════════════════════════════════════════════════════════════
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: {{ .Values.tenantReadonly.clusterRoleName }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/role-type: tenant-readonly
  annotations:
    platform.io/description: "Limited read access. Tenant members for observability. No secrets, no exec."
rules:
  # ── Pods (read + logs only — NO exec, NO port-forward) ─────────────────
  - apiGroups: [""]
    resources: ["pods", "pods/log"]
    verbs: ["get", "list", "watch"]
  # ── Workload resources ──────────────────────────────────────────────────
  - apiGroups: ["apps"]
    resources: ["deployments", "replicasets", "statefulsets", "daemonsets"]
    verbs: ["get", "list", "watch"]
  # ── Services and networking ──────────────────────────────────────────────
  - apiGroups: [""]
    resources: ["services", "endpoints", "configmaps"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["networking.k8s.io"]
    resources: ["ingresses"]
    verbs: ["get", "list", "watch"]
  # ── Events (for debugging) ───────────────────────────────────────────────
  - apiGroups: [""]
    resources: ["events"]
    verbs: ["get", "list", "watch"]
  # ── Namespaces (can see that namespaces exist) ───────────────────────────
  - apiGroups: [""]
    resources: ["namespaces"]
    verbs: ["get", "list", "watch"]
  # ── Nodes (capacity awareness only) ─────────────────────────────────────
  - apiGroups: [""]
    resources: ["nodes"]
    verbs: ["get", "list", "watch"]
  # ── Batch ────────────────────────────────────────────────────────────────
  - apiGroups: ["batch"]
    resources: ["cronjobs", "jobs"]
    verbs: ["get", "list", "watch"]
  # ── HPA ──────────────────────────────────────────────────────────────────
  - apiGroups: ["autoscaling"]
    resources: ["horizontalpodautoscalers"]
    verbs: ["get", "list", "watch"]
  # ── PDB ──────────────────────────────────────────────────────────────────
  - apiGroups: ["policy"]
    resources: ["poddisruptionbudgets"]
    verbs: ["get", "list", "watch"]
  # ── Karpenter NodePools (tenant-scoped view) ─────────────────────────────
  - apiGroups: ["karpenter.sh"]
    resources: ["nodepools", "nodeclaims"]
    verbs: ["get", "list", "watch"]
  # ── Metrics (for kubectl top) ────────────────────────────────────────────
  - apiGroups: ["metrics.k8s.io"]
    resources: ["pods", "nodes"]
    verbs: ["get", "list"]
  # ── Explicitly DENY: secrets, exec, port-forward, attach ─────────────────
  # (Not listing them = they are denied by default in K8s RBAC)

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EKS Platform RBAC Architecture</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg: #0a0d14;
    --surface: #111520;
    --surface2: #161c2d;
    --border: #1e2840;
    --border2: #263354;
    --text: #e2e8f0;
    --text-dim: #64748b;
    --text-muted: #334155;
    --aws-orange: #ff9900;
    --aws-orange-dim: rgba(255,153,0,0.15);
    --platform-blue: #3b82f6;
    --platform-blue-dim: rgba(59,130,246,0.12);
    --tenant-green: #10b981;
    --tenant-green-dim: rgba(16,185,129,0.12);
    --rbac-purple: #a855f7;
    --rbac-purple-dim: rgba(168,85,247,0.12);
    --read-teal: #06b6d4;
    --read-teal-dim: rgba(6,182,212,0.12);
    --write-amber: #f59e0b;
    --write-amber-dim: rgba(245,158,11,0.12);
    --danger: #ef4444;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    min-height: 100vh;
    padding: 40px 32px;
    background-image:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 90% 80%, rgba(168,85,247,0.05) 0%, transparent 50%);
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.5px;
    color: var(--text);
    text-align: center;
    margin-bottom: 6px;
  }

  .subtitle {
    text-align: center;
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 48px;
  }

  /* ── Layout ── */
  .canvas {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 24px;
  }

  /* ── Reusable box ── */
  .box {
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 20px 24px;
    position: relative;
  }

  .box-label {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 16px;
  }

  .tag {
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
    font-weight: 600;
  }

  /* ── Top row: IAM + Access Entries ── */
  .row-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  /* ── AWS IAM Panel ── */
  .iam-panel {
    border-color: rgba(255,153,0,0.3);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(255,153,0,0.04) 100%);
  }

  .iam-panel .box-label { background: var(--aws-orange-dim); color: var(--aws-orange); }

  .roles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .iam-role {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    background: var(--surface2);
  }

  .iam-role.platform-write { border-color: rgba(59,130,246,0.4); }
  .iam-role.platform-read  { border-color: rgba(6,182,212,0.4); }
  .iam-role.tenant-write   { border-color: rgba(16,185,129,0.4); }
  .iam-role.tenant-read    { border-color: rgba(245,158,11,0.4); }

  .role-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 12px;
    margin-bottom: 4px;
  }

  .role-arn {
    font-size: 9px;
    color: var(--text-dim);
    word-break: break-all;
    line-height: 1.5;
    margin-bottom: 8px;
  }

  /* ── Access Entries Panel ── */
  .access-panel {
    border-color: rgba(168,85,247,0.3);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(168,85,247,0.04) 100%);
  }

  .access-panel .box-label { background: var(--rbac-purple-dim); color: var(--rbac-purple); }

  .entry-row {
    display: grid;
    grid-template-columns: 1fr 28px 1fr;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .entry-row:last-child { margin-bottom: 0; }

  .entry-iam {
    font-size: 10px;
    padding: 7px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--aws-orange);
    text-align: right;
  }

  .arrow-mid {
    text-align: center;
    color: var(--border2);
    font-size: 14px;
  }

  .entry-k8s {
    font-size: 10px;
    padding: 7px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--surface2);
  }

  /* ── EKS Cluster ── */
  .cluster-box {
    border-color: rgba(59,130,246,0.35);
    background: linear-gradient(180deg, var(--surface) 0%, rgba(59,130,246,0.03) 100%);
  }

  .cluster-box .box-label { background: var(--platform-blue-dim); color: var(--platform-blue); }

  .cluster-inner {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 20px;
  }

  /* ── Platform Namespaces ── */
  .platform-ns-panel {
    border: 1px solid rgba(59,130,246,0.25);
    border-radius: 8px;
    padding: 14px;
    background: rgba(59,130,246,0.04);
  }

  .panel-title {
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--platform-blue);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ns-chip {
    display: inline-block;
    font-size: 9px;
    padding: 4px 9px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--surface2);
    margin: 3px;
    color: var(--text-dim);
  }

  .ns-chip.highlight {
    border-color: rgba(59,130,246,0.4);
    color: var(--platform-blue);
    background: var(--platform-blue-dim);
  }

  /* ── Tenant Namespaces ── */
  .tenants-area {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tenant-block {
    border: 1px solid rgba(16,185,129,0.25);
    border-radius: 8px;
    padding: 12px 14px;
    background: rgba(16,185,129,0.03);
  }

  .tenant-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .tenant-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 11px;
    color: var(--tenant-green);
    letter-spacing: 1px;
  }

  .tenant-ns-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 8px;
  }

  .tenant-ns {
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 4px;
    border: 1px solid rgba(16,185,129,0.3);
    background: rgba(16,185,129,0.08);
    color: var(--tenant-green);
  }

  .argocd-note {
    font-size: 9px;
    color: var(--text-dim);
    padding: 5px 8px;
    border-radius: 4px;
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.2);
    color: var(--write-amber);
  }

  /* ── RBAC Bindings ── */
  .rbac-section {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .rbac-card {
    border-radius: 8px;
    border: 1px solid var(--border);
    padding: 16px;
    background: var(--surface2);
    position: relative;
    overflow: hidden;
  }

  .rbac-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
  }

  .rbac-card.platform-write::before { background: var(--platform-blue); }
  .rbac-card.platform-read::before  { background: var(--read-teal); }
  .rbac-card.tenant-write::before   { background: var(--tenant-green); }
  .rbac-card.tenant-read::before    { background: var(--write-amber); }

  .rbac-card-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 12px;
    margin-bottom: 4px;
  }

  .platform-write .rbac-card-title { color: var(--platform-blue); }
  .platform-read  .rbac-card-title { color: var(--read-teal); }
  .tenant-write   .rbac-card-title { color: var(--tenant-green); }
  .tenant-read    .rbac-card-title { color: var(--write-amber); }

  .rbac-kind {
    font-size: 9px;
    color: var(--text-dim);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .perm-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .perm-item {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    font-size: 9px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .perm-item::before {
    content: '▸';
    flex-shrink: 0;
    margin-top: 1px;
  }

  .platform-write .perm-item::before { color: var(--platform-blue); }
  .platform-read  .perm-item::before { color: var(--read-teal); }
  .tenant-write   .perm-item::before { color: var(--tenant-green); }
  .tenant-read    .perm-item::before { color: var(--write-amber); }

  /* ── ArgoCD flow ── */
  .argocd-section {
    display: grid;
    grid-template-columns: 1fr 80px 1fr;
    gap: 0;
    align-items: center;
  }

  .argocd-box {
    border-color: rgba(245,158,11,0.3);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(245,158,11,0.04) 100%);
  }

  .argocd-box .box-label { background: var(--write-amber-dim); color: var(--write-amber); }

  .flow-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: var(--text-dim);
    font-size: 9px;
    letter-spacing: 1px;
  }

  .flow-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--border2), transparent);
  }

  .flow-chevron { font-size: 14px; color: var(--border2); }

  .repo-structure {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 4px;
  }

  .repo-box {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 10px 12px;
