        <div style="margin-top:10px">
          <div style="font-family:'Syne',sans-serif;font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-dim);margin-bottom:6px">Node Groups</div>
          <span class="ns-chip highlight">platform-system-ng</span>
