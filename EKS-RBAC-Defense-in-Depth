      </div>
    </div>
  </div>

  <!-- connector -->
  <div class="connector-row">
    <div class="connector-line"></div>
    <span class="badge">helm-managed rbac</span>
    <div class="connector-line"></div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       ROW 3 — RBAC Role Cards
  ════════════════════════════════════════════════════ -->
  <div class="rbac-section">

    <div class="rbac-card platform-write">
      <div class="rbac-card-title">Platform Admin</div>
      <div class="rbac-kind">ClusterRole · Helm: platform-rbac</div>
      <ul class="perm-list">
        <li class="perm-item">All API groups (*) full CRUD</li>
        <li class="perm-item">All namespaces incl. platform NSes</li>
        <li class="perm-item">Node, PV, ClusterRole management</li>
        <li class="perm-item">CRD create/update/patch/delete</li>
        <li class="perm-item">Karpenter NodeClass & NodePool admin</li>
        <li class="perm-item">ArgoCD Application admin</li>
        <li class="perm-item">Secrets, ConfigMaps full access</li>
      </ul>
      <div style="margin-top:10px;font-size:9px;padding:5px 8px;border-radius:4px;background:var(--platform-blue-dim);color:var(--platform-blue)">
        Group: platform-admins
      </div>
    </div>

    <div class="rbac-card platform-read">
      <div class="rbac-card-title">Platform ReadOnly</div>
      <div class="rbac-kind">ClusterRole · Helm: platform-rbac</div>
      <ul class="perm-list">
        <li class="perm-item">get, list, watch on all resources</li>
        <li class="perm-item">All namespaces incl. platform NSes</li>
        <li class="perm-item">Nodes, PVs, PVCs read</li>
        <li class="perm-item">Events, Logs read access</li>
        <li class="perm-item">Karpenter resources read</li>
        <li class="perm-item">ArgoCD Applications read</li>
        <li class="perm-item">Secrets LIST only (no get/watch)</li>
      </ul>
