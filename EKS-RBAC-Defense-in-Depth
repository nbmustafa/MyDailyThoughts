        </div>
      </div>

      <!-- Tenant Namespaces (right column) -->
      <div class="tenants-area">
        <div style="font-family:'Syne',sans-serif;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--tenant-green);margin-bottom:2px;display:flex;align-items:center;gap:8px">
          <span>👥</span> Tenant Namespaces
