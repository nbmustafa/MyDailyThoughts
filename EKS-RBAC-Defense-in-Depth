  }

  .repo-file {
    font-size: 9px;
    color: var(--text-dim);
    padding: 2px 0;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .repo-file .icon { opacity: 0.5; }

  /* ── Legend ── */
  .legend {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
