```

## Deployment Order

```bash
# 1. Apply Terraform (EKS + IAM + Access Entries)
cd terraform/environments/production
terraform init
terraform plan -var="platform_admin_external_id=$EXTERNAL_ID"
terraform apply

# 2. Bootstrap ArgoCD (one-time)
helm upgrade --install argocd argo/argo-cd \
  --namespace argocd --create-namespace \
  -f helm-values/argocd.yaml

# 3. Apply the App-of-Apps — ArgoCD takes over from here
kubectl apply -f argocd/platform/apps/app-of-apps.yaml

# 4. Onboard a new tenant (add to values.yaml + tfvars, then PR)
# → platform-rbac Helm auto-syncs via ArgoCD
# → Terraform access-entries auto-provisions via CI/CD
```

## Adding a New Tenant

1. Add to `terraform.tfvars`:
```hcl
tenants = {
  "team-gamma" = {
    write_principal_arns = ["arn:aws:iam::ACCOUNT:role/team-gamma-sso"]
    read_principal_arns  = ["arn:aws:iam::ACCOUNT:role/team-gamma-read-sso"]
    namespaces           = ["tenant-gamma-dev", "tenant-gamma-prod"]
  }
}
```

2. Add to `helm/platform-rbac/values.yaml`:
```yaml
tenants:
  - name: team-gamma
    k8sGroup: tenant-team-gamma-writers
    namespaces:
      - tenant-gamma-dev
      - tenant-gamma-prod
```

3. Add ArgoCD Application pointing at their gitops repo.

4. Merge PR → CI runs `terraform apply` → ArgoCD syncs Helm chart → done.

## Security Decisions

- **No aws-auth ConfigMap**: Fully replaced by EKS Access Entries API (`authenticationMode: API`)
- **IMDSv2 enforced**: `http_tokens: required` on all launch templates
- **Secrets encryption**: KMS with key rotation enabled
- **Node isolation**: Platform nodes have `NoSchedule` taint — tenant workloads cannot run there
- **NetworkPolicy**: Default-deny ingress on all tenant namespaces
- **Tenant namespace scope**: Tenant write Role is namespace-scoped, never ClusterRole
- **Secrets access**: Tenant readers cannot `get`/`watch` secrets — list only for platform readers
- **MFA required**: Platform admin role requires `aws:MultiFactorAuthPresent: true`
- **ArgoCD AppProject**: Tenants cannot deploy to platform namespaces via ArgoCD
- **Karpenter limits**: Hard CPU/memory limits on each tenant NodePool

###############################################################################
# Per-Tenant Namespace Resources
# Generates for EACH tenant × EACH namespace:
#   - Namespace (with labels)
#   - Role (namespace-scoped write)
#   - RoleBinding (namespace-scoped)
#   - ResourceQuota
#   - LimitRange
#   - NetworkPolicy (default deny + allow same-ns)
###############################################################################

{{- range .Values.tenants }}
{{- $tenant := . }}
{{- range .namespaces }}
{{- $ns := . }}
---
# ── Namespace: {{ $ns }} ────────────────────────────────────────────────
apiVersion: v1
kind: Namespace
metadata:
  name: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
    platform.io/managed: "true"
  annotations:
    platform.io/tenant-name: {{ $tenant.name }}
    platform.io/provisioned-by: "platform-team"

---
# ── Tenant Write Role: {{ $tenant.name }} in {{ $ns }} ─────────────────
# Namespace-scoped: tenant writers can ONLY affect their own namespace
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: tenant-writer
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
    platform.io/role-type: tenant-write
  annotations:
    platform.io/description: "Write access for {{ $tenant.name }} in {{ $ns }} only."
rules:
  # ── Workloads ──────────────────────────────────────────────────────────
  - apiGroups: ["apps"]
    resources:
      - deployments
      - replicasets
      - statefulsets
      - daemonsets
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── Pods ────────────────────────────────────────────────────────────────
  - apiGroups: [""]
    resources: ["pods"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["pods/log", "pods/status"]
    verbs: ["get", "list", "watch"]
  # ── Pod exec + port-forward for debugging (write role only) ─────────────
  - apiGroups: [""]
    resources: ["pods/exec", "pods/portforward"]
    verbs: ["create"]
  # ── Services and networking ──────────────────────────────────────────────
  - apiGroups: [""]
    resources: ["services", "endpoints"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: ["networking.k8s.io"]
    resources: ["ingresses"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── ConfigMaps + Secrets (own namespace only) ────────────────────────────
  - apiGroups: [""]
    resources: ["configmaps"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── ServiceAccounts (own namespace only) ─────────────────────────────────
  - apiGroups: [""]
    resources: ["serviceaccounts"]
    verbs: ["get", "list", "watch", "create", "update", "patch"]
  # ── Batch ────────────────────────────────────────────────────────────────
  - apiGroups: ["batch"]
    resources: ["cronjobs", "jobs"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── Autoscaling ──────────────────────────────────────────────────────────
  - apiGroups: ["autoscaling"]
    resources: ["horizontalpodautoscalers"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: ["autoscaling.k8s.io"]
    resources: ["verticalpodautoscalers"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── PDB ──────────────────────────────────────────────────────────────────
  - apiGroups: ["policy"]
    resources: ["poddisruptionbudgets"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── PVCs ─────────────────────────────────────────────────────────────────
  - apiGroups: [""]
    resources: ["persistentvolumeclaims"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── Events (read only for debugging) ─────────────────────────────────────
  - apiGroups: [""]
    resources: ["events"]
    verbs: ["get", "list", "watch"]
  # ── ResourceQuota + LimitRange (read only — set by platform) ─────────────
  - apiGroups: [""]
    resources: ["resourcequotas", "limitranges"]
    verbs: ["get", "list", "watch"]
  # ── ExternalSecrets (if using external-secrets operator) ─────────────────
  - apiGroups: ["external-secrets.io"]
    resources: ["externalsecrets", "secretstores"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  # ── ArgoCD Applications (own namespace only) ──────────────────────────────
  - apiGroups: ["argoproj.io"]
    resources: ["applications", "applicationsets"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]

---
# ── RoleBinding: tenant-{{ $tenant.name }}-writers → tenant-writer in {{ $ns }}
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: tenant-writer-binding
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
    platform.io/role-type: tenant-write
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: tenant-writer
subjects:
  - kind: Group
    name: {{ $tenant.k8sGroup }}
    apiGroup: rbac.authorization.k8s.io

{{- if $.Values.resourceQuotas.enabled }}
---
# ── ResourceQuota for {{ $ns }} ────────────────────────────────────────
apiVersion: v1
kind: ResourceQuota
metadata:
  name: tenant-quota
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
spec:
  hard:
    {{- range $k, $v := $.Values.resourceQuotas.default }}
    {{ $k }}: {{ $v | quote }}
    {{- end }}
{{- end }}

{{- if $.Values.limitRanges.enabled }}
---
# ── LimitRange for {{ $ns }} ───────────────────────────────────────────
apiVersion: v1
kind: LimitRange
metadata:
  name: tenant-limits
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
spec:
  limits:
    - type: Container
      defaultRequest:
        cpu: {{ $.Values.limitRanges.default.container.defaultRequest.cpu | quote }}
        memory: {{ $.Values.limitRanges.default.container.defaultRequest.memory | quote }}
      default:
        cpu: {{ $.Values.limitRanges.default.container.default.cpu | quote }}
        memory: {{ $.Values.limitRanges.default.container.default.memory | quote }}
      max:
        cpu: {{ $.Values.limitRanges.default.container.max.cpu | quote }}
        memory: {{ $.Values.limitRanges.default.container.max.memory | quote }}
{{- end }}

{{- if $.Values.networkPolicy.enabled }}
---
# ── NetworkPolicy: default-deny-ingress for {{ $ns }} ─────────────────
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: default-deny-ingress
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
spec:
  podSelector: {}
  policyTypes:
    - Ingress

---
# ── NetworkPolicy: allow-same-namespace for {{ $ns }} ─────────────────
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-same-namespace
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
spec:
  podSelector: {}
  policyTypes:
    - Ingress
  ingress:
    - from:
        - podSelector: {}

---
# ── NetworkPolicy: allow-monitoring-scrape for {{ $ns }} ──────────────
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-monitoring-scrape
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/managed-by: platform-rbac-helm
    platform.io/tenant: {{ $tenant.name }}
spec:
  podSelector: {}
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: monitoring
      ports:
        - protocol: TCP
          port: 9090
        - protocol: TCP
          port: 8080
        - protocol: TCP
          port: 9091
{{- end }}

{{- end }}{{/* end range namespaces */}}
{{- end }}{{/* end range tenants */}}

###############################################################################
# platform-rbac — values.yaml
###############################################################################

# Platform namespace list (tenants must NEVER have write access here)
platformNamespaces:
  - kube-system
  - kube-public
  - kube-node-lease
  - argocd
  - karpenter
  - monitoring
  - cert-manager
  - external-dns
  - ingress-nginx
  - external-secrets
  - velero
  - falco

# ── Platform Admin ClusterRole ─────────────────────────────────────────────
platformAdmin:
  clusterRoleName: platform-admin
  clusterRoleBindingName: platform-admin-binding
  # K8s group that access entries map the IAM role to
  k8sGroup: platform-admins

# ── Platform ReadOnly ClusterRole ──────────────────────────────────────────
platformReadonly:
  clusterRoleName: platform-readonly
  clusterRoleBindingName: platform-readonly-binding
  k8sGroup: platform-readers

# ── Tenant ReadOnly ClusterRole ────────────────────────────────────────────
# Tenants with read roles get this ClusterRole — allows them to see
# all workloads but NOT secrets, exec, or port-forward
tenantReadonly:
  clusterRoleName: tenant-readonly
  clusterRoleBindingName: tenant-readonly-binding
  k8sGroup: tenant-readers    # all tenant-read access entries share this group

# ── Tenant Write (namespace-scoped) ───────────────────────────────────────
# One Role + RoleBinding per namespace per tenant
# Tenants can only write to their own namespaces
tenants:
  - name: team-alpha
    k8sGroup: tenant-team-alpha-writers
    namespaces:
      - tenant-alpha-dev
      - tenant-alpha-staging
      - tenant-alpha-prod

  - name: team-beta
    k8sGroup: tenant-team-beta-writers
    namespaces:
      - tenant-beta-dev
      - tenant-beta-prod

# Resource quotas applied to each tenant namespace
resourceQuotas:
  enabled: true
  default:
    requests.cpu: "4"
    requests.memory: "8Gi"
    limits.cpu: "16"
    limits.memory: "32Gi"
    count/pods: "50"
    count/services: "20"
    count/persistentvolumeclaims: "10"

# LimitRange defaults per tenant namespace
limitRanges:
  enabled: true
  default:
    container:
      defaultRequest:
        cpu: "100m"
        memory: "128Mi"
      default:
        cpu: "500m"
        memory: "512Mi"
      max:
        cpu: "4"
        memory: "8Gi"

# NetworkPolicy — deny all cross-tenant traffic by default
networkPolicy:
  enabled: true
  denyAllIngress: true        # override per namespace
  allowIngressFromSameNS: true
  allowIngressFromMonitoring: true
  allowEgress: true
