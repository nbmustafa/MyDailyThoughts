        <div class="repo-file" style="padding-left:16px"><span class="icon">📄</span>tenant-b-app.yaml</div>
      </div>

      <div class="repo-box">
        <div class="repo-box-title" style="color:var(--tenant-green)">📁 tenant-gitops (per-tenant write access)</div>
        <div class="repo-file"><span class="icon">📂</span>karpenter/</div>
        <div class="repo-file" style="padding-left:16px"><span class="icon">📄</span>ec2nodeclass.yaml</div>
        <div class="repo-file" style="padding-left:16px"><span class="icon">📄</span>nodepool.yaml</div>
        <div class="repo-file"><span class="icon">📂</span>namespaces/</div>
        <div class="repo-file" style="padding-left:16px"><span class="icon">📄</span>dev-namespace.yaml</div>
        <div class="repo-file" style="padding-left:16px"><span class="icon">📄</span>prod-namespace.yaml</div>
        <div class="repo-file"><span class="icon">📂</span>apps/</div>
        <div class="repo-file" style="padding-left:16px"><span class="icon">📄</span>workload-app.yaml</div>
      </div>

      <div class="repo-box">
        <div class="repo-box-title" style="color:var(--rbac-purple)">🔄 Tenant Onboarding Flow</div>
        <div style="font-size:9px;color:var(--text-dim);line-height:1.8">
