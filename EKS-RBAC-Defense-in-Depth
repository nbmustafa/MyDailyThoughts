    border-radius: 20px;
    background: var(--surface2);
    border: 1px solid var(--border2);
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .karpenter-badge {
    font-size: 9px;
    padding: 2px 7px;
    border-radius: 3px;
    background: rgba(168,85,247,0.1);
    border: 1px solid rgba(168,85,247,0.3);
